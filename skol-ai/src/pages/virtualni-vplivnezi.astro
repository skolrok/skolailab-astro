---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServiceTemplate from "../components/service/ServiceTemplate.astro";
import CloudinaryVideo from "../components/CloudinaryVideo.astro";
import { services, serviceJsonLd } from "../data/services";

const service = services["virtualni-vplivnezi"];
const siteUrl = (Astro.site ?? new URL("https://skolailab.com")).origin;
const schema = serviceJsonLd(service, siteUrl);

const aiModelVideo =
  "https://res.cloudinary.com/ddl75cyhk/video/upload/f_auto/v1773247789/ai-agencija-skol-ai-virtualni-ambasador_jnpxz1.mp4";
---

<BaseLayout
  titleExact={service.metaTitle}
  description={service.metaDescription}
  ogType="article"
  jsonLd={schema}
>
  <ServiceTemplate service={service}>
    <figure slot="media" class="vv-proof">
      <div class="vv-proof__frame">
        <CloudinaryVideo src={aiModelVideo} />
      </div>
      <figcaption class="vv-proof__cap">
        <span class="vv-proof__tag">Dokaz storitve</span>
        Virtualni ambasador, zgrajen z AI — 100 % konsistenten, 24/7 prisoten.
      </figcaption>
    </figure>
  </ServiceTemplate>
</BaseLayout>

<style>
  .vv-proof { margin: 0; display: grid; gap: 1.25rem; }
  @media (min-width: 720px) {
    .vv-proof { grid-template-columns: auto 1fr; align-items: end; gap: 2rem; }
  }
  .vv-proof__frame {
    position: relative;
    width: 100%;
    max-width: 420px;
    aspect-ratio: 4 / 5; /* rezervira prostor -> brez CLS */
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--color-hairline);
    background: var(--color-ink-2);
  }
  .vv-proof__cap {
    max-width: 38ch;
    color: var(--color-bone-dim);
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .vv-proof__tag {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 0.5rem;
  }
</style>
