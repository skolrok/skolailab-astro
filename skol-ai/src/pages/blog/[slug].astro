---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const { title, description, pubDate, updatedDate, author, tags, image } = post.data;

const siteOrigin = Astro.site ?? new URL("https://skolailab.com");
const siteUrl = siteOrigin.origin;
const url = new URL(`/blog/${post.id}/`, siteOrigin).href;

const fmtDate = (d: Date) =>
  new Intl.DateTimeFormat("sl-SI", { day: "numeric", month: "long", year: "numeric" }).format(d);
const isUpdated = updatedDate && updatedDate.getTime() !== pubDate.getTime();

// TOC: h2/h3, samo za daljše članke (>= 3 naslovi)
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
const showToc = toc.length >= 3;

// OG: če ima članek cover, ga transformiraj v 1200×630; sicer brand default
const ogOverride = image
  ? `https://res.cloudinary.com/ddl75cyhk/image/upload/f_jpg,q_auto,c_fill,w_1200,h_630/${image}`
  : "/og/default.png";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "@id": `${url}#article`,
    headline: title,
    description,
    url,
    mainEntityOfPage: url,
    datePublished: pubDate.toISOString(),
    dateModified: (updatedDate ?? pubDate).toISOString(),
    author: { "@type": "Person", name: author },
    publisher: { "@id": `${siteUrl}/#organization` },
    inLanguage: "sl-SI",
    keywords: tags.join(", "),
    ...(image && {
      image: `https://res.cloudinary.com/ddl75cyhk/image/upload/f_jpg,q_auto,c_fill,w_1200,h_630/${image}`,
    }),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": `${url}#breadcrumb`,
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Domov", item: `${siteUrl}/` },
      { "@type": "ListItem", position: 2, name: "Blog", item: `${siteUrl}/blog` },
      { "@type": "ListItem", position: 3, name: title, item: url },
    ],
  },
];
---

<BaseLayout titleExact={`${title} | SKOL AI`} description={description} ogType="article" image={ogOverride} jsonLd={schema}>
  <article class="post">
    <header class="post__head">
      <div class="container-page">
        <nav class="breadcrumb" aria-label="Drobtinice" data-hero>
          <a href="/">Domov</a>
          <span aria-hidden="true">/</span>
          <a href="/blog">Blog</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">{title}</span>
        </nav>

        {tags[0] && <p class="kicker post__kicker" data-hero>[ {tags[0]} ]</p>}
        <h1 class="post__title" data-hero>{title}</h1>

        <div class="post__meta" data-hero>
          <span class="post__author">{author}</span>
          <span class="post__sep" aria-hidden="true">·</span>
          <time datetime={pubDate.toISOString()}>{fmtDate(pubDate)}</time>
          {isUpdated && (
            <>
              <span class="post__sep" aria-hidden="true">·</span>
              <span class="post__updated">posodobljeno {fmtDate(updatedDate!)}</span>
            </>
          )}
        </div>
      </div>
    </header>

    <div class="container-page post__wrap">
      {showToc && (
        <aside class="post__toc" data-reveal aria-label="Kazalo">
          <p class="post__toc-label">Kazalo</p>
          <ol class="post__toc-list">
            {toc.map((h) => (
              <li class:list={["post__toc-item", { "is-sub": h.depth === 3 }]}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ol>
        </aside>
      )}

      <div class="post__body" data-reveal>
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  /* ---------- HEAD ---------- */
  .post__head { padding-top: clamp(2.5rem, 7vh, 5.5rem); padding-bottom: clamp(1.5rem, 4vh, 3rem); }
  .post__kicker { margin-top: 1.5rem; }
  .post__title {
    margin-top: 1rem;
    font-family: var(--font-display); font-weight: 500;
    font-size: clamp(34px, 6vw, 76px); line-height: 1.02; letter-spacing: -0.01em;
    max-width: 20ch;
  }
  .post__meta {
    margin-top: 1.75rem;
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.6rem;
    font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.06em;
    color: var(--color-bone-dim);
  }
  .post__author { color: var(--color-gold); }
  .post__sep { color: var(--color-gold); opacity: 0.6; }
  .post__updated { color: var(--color-bone-dim); }

  /* ---------- WRAP (TOC + body) ---------- */
  .post__wrap {
    padding-block: clamp(1.5rem, 4vh, 3rem) clamp(4rem, 9vh, 7rem);
    border-top: 1px solid var(--color-hairline);
  }
  @media (min-width: 1080px) {
    .post__wrap {
      display: grid;
      grid-template-columns: 220px minmax(0, 680px);
      justify-content: center;
      gap: clamp(2rem, 4vw, 4rem);
      align-items: start;
    }
  }

  /* ---------- TOC ---------- */
  .post__toc {
    margin-bottom: 2.5rem;
    padding: 1.25rem 1.4rem;
    border: 1px solid var(--color-hairline);
    border-radius: 12px;
    background: var(--color-ink-2);
  }
  @media (min-width: 1080px) {
    .post__toc { position: sticky; top: 6rem; margin-bottom: 0; background: transparent; border: none; padding: 0; padding-left: 1rem; border-left: 1px solid var(--color-hairline); }
  }
  .post__toc-label {
    font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--color-gold); margin-bottom: 0.85rem;
  }
  .post__toc-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.6rem; }
  .post__toc-item.is-sub { padding-left: 1rem; }
  .post__toc-item a {
    font-size: 0.85rem; line-height: 1.4; color: var(--color-bone-dim);
    transition: color 0.25s var(--ease-reveal);
  }
  .post__toc-item a:hover { color: var(--color-gold); }

  /* ---------- BODY (berljiva tipografija, ~680px) ---------- */
  .post__body { max-width: 680px; }
  .post__body :global(> p:first-of-type) {
    font-size: clamp(1.15rem, 1.7vw, 1.4rem);
    line-height: 1.6;
    color: var(--color-bone);
    border-left: 2px solid rgb(200 169 110 / 0.45);
    padding-left: 1.25rem;
    margin-bottom: 2rem;
  }
  .post__body :global(p) {
    font-family: var(--font-body);
    font-size: 1.075rem; line-height: 1.75; color: var(--color-bone-dim);
    margin: 0 0 1.5rem;
  }
  .post__body :global(h2) {
    font-family: var(--font-display); font-weight: 500;
    font-size: clamp(1.5rem, 3vw, 2rem); line-height: 1.15; letter-spacing: -0.01em;
    color: var(--color-bone); margin: 2.75rem 0 1rem; scroll-margin-top: 6rem;
  }
  .post__body :global(h3) {
    font-family: var(--font-display); font-weight: 500;
    font-size: clamp(1.25rem, 2.2vw, 1.5rem); line-height: 1.2;
    color: var(--color-bone); margin: 2.25rem 0 0.85rem; scroll-margin-top: 6rem;
  }
  .post__body :global(a) { color: var(--color-gold); text-decoration: underline; text-underline-offset: 3px; }
  .post__body :global(ul), .post__body :global(ol) { margin: 0 0 1.5rem; padding-left: 1.25rem; color: var(--color-bone-dim); }
  .post__body :global(li) { font-size: 1.075rem; line-height: 1.7; margin: 0 0 0.6rem; }
  .post__body :global(li)::marker { color: var(--color-gold); }
  .post__body :global(strong) { color: var(--color-bone); font-weight: 700; }
  .post__body :global(blockquote) {
    margin: 2rem 0; padding-left: 1.5rem; border-left: 2px solid var(--color-gold);
    font-family: var(--font-display); font-style: italic; color: var(--color-bone);
  }
  .post__body :global(img) { width: 100%; height: auto; border-radius: 12px; margin: 2rem 0; }
  .post__body :global(code) {
    font-family: var(--font-mono); font-size: 0.9em;
    background: var(--color-ink-2); border: 1px solid var(--color-hairline);
    border-radius: 6px; padding: 0.1rem 0.4rem;
  }

  /* ---------- Tabele (GFM) — brand grid, gold header, mobilno skrolanje ---------- */
  .post__body :global(.table-scroll) {
    margin: 2rem 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .post__body :global(table) {
    width: 100%;
    min-width: 30rem; /* pod tem se skrola namesto zlepi */
    border-collapse: collapse;
    font-family: var(--font-body);
    font-size: 0.98rem;
    line-height: 1.5;
  }
  .post__body :global(th),
  .post__body :global(td) {
    padding: 0.75rem 1rem; /* ~12px 16px */
    text-align: left;
    vertical-align: top;
    border: 1px solid rgb(237 232 223 / 0.12); /* hairline: vert + horiz ločnice */
    color: var(--color-bone-dim);
  }
  .post__body :global(thead th) {
    color: var(--color-bone);
    font-weight: 700;
    border-bottom: 2px solid var(--color-gold); /* poudarjena spodnja črta */
    white-space: nowrap;
  }
  .post__body :global(tbody td:first-child) {
    color: var(--color-bone); /* prvi stolpec malo poudarjen */
    font-weight: 500;
  }
  .post__body :global(tbody tr:nth-child(even)) {
    background: rgb(237 232 223 / 0.025); /* subtilna zebra za berljivost */
  }
</style>
