---
/* Wordmark — "SKOL Ai" (velika A, mala dotless ı) z zlato iskrico kot piko nad i.
   Varianta 2 (statična) povsod; signature=true doda utripajoč kazalec (loader/footer).
   Velikost se deduje iz konteksta (font-size na wrapperju); iskrica + kazalec sta v em.
   Dostopnost: vidni glifi so aria-hidden, pravo ime pove sr-only "SKOL Ai". */
interface Props {
  signature?: boolean;
  class?: string;
}
const { signature = false, class: klass } = Astro.props;
---

<span class:list={["wm", klass]}>
  <span class="wm__vis" aria-hidden="true"
    ><span class="wm__skol">SKOL</span><span class="wm__ai">A<span class="wm__i"><span class="wm__stem">ı</span><span class="wm__tit"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0C12 6.6 6.6 12 0 12C6.6 12 12 17.4 12 24C12 17.4 17.4 12 24 12C17.4 12 12 6.6 12 0Z"/></svg></span></span></span>{signature && <span class="wm__cursor"></span>}</span
  ><span class="sr-only">SKOL Ai</span>
</span>

<style>
  .wm {
    font-family: var(--font-display);
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-bone);
    line-height: 1;
    white-space: nowrap;
  }
  .wm__vis { display: inline-flex; align-items: baseline; }
  .wm__ai { color: var(--color-gold); margin-left: 0.28em; display: inline-flex; align-items: baseline; }
  .wm__i { position: relative; display: inline-block; }
  .wm__stem { display: inline-block; }
  .wm__tit {
    position: absolute; left: 50%; top: -0.02em;
    transform: translateX(-50%); line-height: 0;
  }
  .wm__tit svg { width: 0.42em; height: 0.42em; display: block; fill: var(--color-gold); }

  .wm__cursor {
    display: inline-block; align-self: center;
    width: 0.1em; height: 0.8em; margin-left: 0.14em;
    background: var(--color-gold);
    animation: wmBlink 1.1s steps(1) infinite;
  }
  @keyframes wmBlink { 0%, 50% { opacity: 1; } 50.01%, 100% { opacity: 0; } }
  @media (prefers-reduced-motion: reduce) { .wm__cursor { animation: none; opacity: 0.6; } }
</style>
