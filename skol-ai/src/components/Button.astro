---
/* Button — primarni (gold fill) ali ghost (besedilo + puščica).
   Hover obrne barvo (gold fill ↔ outline), mikro 0.3s expo-out. */
interface Props {
  href: string;
  variant?: "primary" | "ghost";
  class?: string;
  dl?: string; // dataLayer event (npr. cta_click)
  external?: boolean;
}
const { href, variant = "primary", class: klass = "", dl, external = false } = Astro.props;
const rel = external ? "noopener noreferrer" : undefined;
const target = external ? "_blank" : undefined;
---

<a
  href={href}
  class:list={["btn", `btn--${variant}`, klass]}
  data-dl={dl}
  data-cursor
  rel={rel}
  target={target}
>
  <slot />
</a>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.95rem;
    line-height: 1;
    white-space: nowrap;
    transition: background-color 0.3s var(--ease-reveal),
      color 0.3s var(--ease-reveal),
      border-color 0.3s var(--ease-reveal),
      transform 0.3s var(--ease-reveal);
  }

  /* Primarni: gold fill -> outline ob hoverju */
  .btn--primary {
    background-color: var(--color-gold);
    color: var(--color-ink);
    border: 1px solid var(--color-gold);
    padding: 1rem 1.75rem;
    border-radius: 999px;
  }
  .btn--primary:hover {
    background-color: transparent;
    color: var(--color-gold);
  }

  /* Ghost: besedilo z animirano puščico/podčrto */
  .btn--ghost {
    color: var(--color-bone);
    padding: 1rem 0.25rem;
    position: relative;
  }
  .btn--ghost::after {
    content: "";
    position: absolute;
    left: 0.25rem;
    right: 0.25rem;
    bottom: 0.65rem;
    height: 1px;
    background: var(--color-gold);
    transform: scaleX(0);
    transform-origin: 0 50%;
    transition: transform 0.35s var(--ease-reveal);
  }
  .btn--ghost:hover { color: var(--color-gold); }
  .btn--ghost:hover::after { transform: scaleX(1); }
</style>
