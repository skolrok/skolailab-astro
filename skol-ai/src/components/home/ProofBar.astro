---
/* ProofBar — sekcija 2 (homepage-copy.md). Centrirano, pravi referenci. */
const refs = [
  { name: "Solimat", href: "/projekti/solimat" },
  { name: "Bar Bazenček", href: "/projekti/bar-bazencek" },
];
---

<section class="proof">
  <div class="container-page proof__inner">
    <p class="kicker proof__label" data-reveal>[ Izbrani projekti ]</p>
    <div class="proof__names" data-reveal>
      {refs.map((r, i) => (
        <>
          {i > 0 && <span class="proof__sep" aria-hidden="true">·</span>}
          <a href={r.href} class="proof__ref" data-cursor>{r.name}</a>
        </>
      ))}
    </div>
  </div>
</section>

<style>
  .proof {
    border-top: 1px solid var(--color-hairline);
    border-bottom: 1px solid var(--color-hairline);
    padding-block: clamp(3.5rem, 8vw, 6rem);
  }
  .proof__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: clamp(1.25rem, 3vw, 2rem);
  }

  .proof__names {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: center;
    gap: 0.5rem clamp(1.25rem, 3vw, 2rem);
  }
  .proof__ref {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.75rem, 4.5vw, 3.25rem);
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--color-bone);
    transition: color 0.3s var(--ease-reveal);
  }
  .proof__ref:hover { color: var(--color-gold); }
  .proof__sep {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 2.5rem);
    line-height: 1;
    color: var(--color-gold);
    opacity: 0.75;
  }

  /* Mobilno: imeni se zložita pod labelo (brez vmesnega ločila) */
  @media (max-width: 600px) {
    .proof__names { flex-direction: column; gap: 0.85rem; }
    .proof__sep { display: none; }
  }
</style>
