---
/* ServicesOverview — sekcija 3 (homepage-copy.md). 3 glavne storitve flat. */
const items = [
  {
    name: "Premium spletne strani",
    desc: "Bliskovito hitre strani, ki obiskovalca brez trenja spremenijo v kupca.",
    href: "/spletne-strani",
  },
  {
    name: "AI agenti & avtomatizacije",
    desc: "Vaše ročno delo opravi stroj. Klici, rezervacije in follow-up tečejo sami, 24/7.",
    href: "/ai-agenti",
  },
  {
    name: "GEO / AI vidnost",
    desc: "Da vas ChatGPT, Gemini in Perplexity najdejo, razumejo in priporočijo.",
    href: "/geo",
  },
];
---

<section class="services" id="storitve">
  <div class="container-page">
    <header class="sv-head">
      <p class="kicker" data-reveal>[ Naš arzenal ]</p>
      <h2 class="section-title" data-reveal>Kar gradimo.</h2>
    </header>

    <ul class="sv-list">
      {items.map((it) => (
        <li data-reveal>
          <a href={it.href} class="sv-item" data-cursor>
            <span class="sv-item__name">{it.name}</span>
            <span class="sv-item__desc">{it.desc}</span>
            <span class="sv-item__arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>

    <p class="sv-note" data-reveal>
      Delamo tudi AI vizualije, video in oglasne kreative po meri.
    </p>
  </div>
</section>

<style>
  .section-title {
    margin-top: 1.25rem;
    font-family: var(--font-display); font-weight: 500;
    font-size: clamp(34px, 5.5vw, 72px); line-height: 1; letter-spacing: -0.01em;
  }
  .services { padding-block: clamp(4rem, 10vh, 8rem); }
  .sv-head { margin-bottom: clamp(2.5rem, 5vw, 4rem); }

  .sv-list { list-style: none; margin: 0; padding: 0; }
  .sv-item {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas: "name arrow" "desc arrow";
    gap: 0.4rem 1rem;
    align-items: start;
    padding: clamp(1.5rem, 3vw, 2.25rem) 0;
    border-top: 1px solid var(--color-hairline);
    transition: padding-left 0.35s var(--ease-reveal);
  }
  .sv-list li:last-child .sv-item { border-bottom: 1px solid var(--color-hairline); }
  .sv-item:hover { padding-left: 0.75rem; }
  .sv-item__name {
    grid-area: name;
    font-family: var(--font-display); font-weight: 500;
    font-size: clamp(1.4rem, 2.6vw, 2rem); line-height: 1.1; color: var(--color-bone);
    transition: color 0.3s var(--ease-reveal);
  }
  .sv-item:hover .sv-item__name { color: var(--color-gold); }
  .sv-item__desc {
    grid-area: desc;
    font-size: 0.95rem; line-height: 1.5; color: var(--color-bone-dim); max-width: 52ch;
  }
  .sv-item__arrow {
    grid-area: arrow; align-self: center;
    font-family: var(--font-mono); color: var(--color-gold);
    opacity: 0; transform: translateX(-0.4rem);
    transition: opacity 0.35s var(--ease-reveal), transform 0.35s var(--ease-reveal);
  }
  .sv-item:hover .sv-item__arrow { opacity: 1; transform: translateX(0); }

  .sv-note {
    margin-top: clamp(1.5rem, 3vw, 2.25rem);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--color-bone-dim);
    opacity: 0.8;
  }
</style>
