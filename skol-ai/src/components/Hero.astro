---
/* Hero — sekcija 1 (homepage-copy.md). Stopničasto razkritje prek [data-hero]:
   kicker → naslovni vrstici (line-mask) → sub → CTA → tagi. */
import Button from "./Button.astro";

const trust = ["Do 96/100 PageSpeed", "Odgovor v 24 urah", "100% po meri", "Dvojezične strani"];
---

<section class="hero">
  <div class="container-page hero__grid">
    <p class="kicker" data-hero>[ AI Kreativni studio · Trebnje ]</p>

    <h1 class="hero__title">
      <span class="line"><span class="line__in" data-hero>Estetika kot</span></span>
      <span class="line"
        ><span class="line__in" data-hero
          ><em class="accent">nepravična</em> prednost.</span
        ></span
      >
    </h1>

    <p class="hero__sub" data-hero>
      Bliskovito hitre spletne strani, AI agenti in AI vidnost za znamke, ki nočejo biti kot vse
      ostale. Sedež v Trebnjem, gradimo za vso Slovenijo.
    </p>

    <div class="hero__cta" data-hero>
      <Button href="/kontakt" variant="primary" dl="cta_click">Začnimo ustvarjati</Button>
      <Button href="/reference" variant="ghost">Poglej reference →</Button>
    </div>

    <ul class="hero__trust" data-hero aria-label="Zakaj SKOL AI">
      {trust.map((t, i) => (
        <>
          {i > 0 && <li class="hero__trust-sep" aria-hidden="true">·</li>}
          <li class="hero__trust-item">{t}</li>
        </>
      ))}
    </ul>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: calc(100svh - var(--nav-h));
    padding-block: clamp(3rem, 10vh, 8rem);
  }
  .hero__grid {
    display: flex;
    flex-direction: column;
  }

  .hero__title {
    margin-top: 1.75rem;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(44px, 8.4vw, 128px);
    line-height: 0.96;
    letter-spacing: -0.01em;
    max-width: 14ch;
  }
  /* Line-mask: overflow hidden + rahel padding, da italic ne kljuva */
  .line {
    display: block;
    overflow: hidden;
    padding-bottom: 0.08em;
    margin-bottom: -0.08em;
  }
  .line__in { display: block; }
  .accent {
    color: var(--color-gold);
    font-style: italic;
  }

  .hero__sub {
    margin-top: 2rem;
    max-width: 46ch;
    font-size: clamp(15px, 1.5vw, 19px);
    line-height: 1.65;
    color: var(--color-bone-dim);
  }

  .hero__cta {
    margin-top: 3rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.5rem;
  }

  /* Trust vrstica — mono, drobno, zlate pike med postavkami */
  .hero__trust {
    margin-top: 3.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.9rem;
    list-style: none;
    padding: 0;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-bone-dim);
  }
  .hero__trust-sep { color: var(--color-gold); }
</style>
